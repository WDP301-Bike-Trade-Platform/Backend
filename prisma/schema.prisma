generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  role_id   Int      @id @default(autoincrement())
  role_name RoleName @unique
  users     User[]
  @@map("roles")
}

enum VehicleCondition {
  NEW
  USED
}

model User {
  user_id              String           @id @default(uuid())
  full_name            String
  email                String           @unique
  phone                String           @unique
  password             String
  role_id              Int
  violation_count      Int              @default(0)
  locked_until         DateTime?
  created_at           DateTime
  ip_address           String?
  is_verified          Boolean          @default(false)
  addresses            Address[]
  cart                 Cart?            @relation("BuyerCart")
  chatUser1s           Chat[]           @relation("ChatUser1")
  chatUser2s           Chat[]           @relation("ChatUser2")
  inspectionsAssigned  Inspection[]     @relation("Inspector")
  inspectionsRequested Inspection[]     @relation("InspectionRequester")
  listings             Listing[]        @relation("SellerListings")
  messagesReceived     Message[]        @relation("Receiver")
  messagesSent         Message[]        @relation("Sender")
  notifications        Notification[]
  orders               Order[]          @relation("BuyerOrders")
  otps                 Otp[]
  paymentDeposits      PaymentDeposit[]
  reviewAsBuyer        Review[]         @relation("ReviewBuyer")
  reviewsGiven         Review[]         @relation("Reviewer")
  reviewAsSeller       Review[]         @relation("ReviewSeller")
  reviewsReceived      Review[]         @relation("Target")
  transfers            Transfer[]
  profile              UserProfile?
  wishlist             Wishlist?
  reports              Report[]         @relation("UserReports") // 👈 báo cáo do user này tạo
  reportsProcessed     Report[]         @relation("AdminProcessed") // 👈 báo cáo do user này (admin) xử lý
  role                 Role             @relation(fields: [role_id], references: [role_id])
  interactions UserInteraction[] // 👈 thêm dòng này

  @@map("users")
}

model Otp {
  id         String   @id @default(uuid())
  user_id    String
  code       String
  expired_at DateTime
  user       User     @relation(fields: [user_id], references: [user_id])

  @@map("otps")
}

model UserProfile {
  profile_id   String    @id @default(uuid())
  user_id      String    @unique
  dob          DateTime?
  gender       String?
  national_id  String?
  bank_account String?
  bank_name    String?
  avatar_url   String?
  created_at   DateTime
  bank_bin     String?
  user         User      @relation(fields: [user_id], references: [user_id])

  @@map("user_profiles")
}

model Category {
  category_id String     @id @default(uuid())
  name        String
  parent_id   String? // ID danh mục cha (null nếu là danh mục gốc)
  parent      Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [category_id])
  children    Category[] @relation("CategoryHierarchy")
  vehicles    Vehicle[]

  @@map("categories")
}

model Vehicle {
  vehicle_id  String @id @default(uuid())
  category_id String

  brand String
  model String
  year  Int
  price Decimal

  bike_type  String // road, mtb, fixed, gravel...
  material   String // carbon, aluminum...
  brake_type String // disc, rim
  wheel_size String? // 700c, 29, 27.5

  condition   VehicleCondition
  usage_level String? // NEW, LIGHT, HEAVY
  mileage_km  Int? // optional

  groupset   String? // Shimano 105, SRAM Rival...
  frame_size String?

  is_original  Boolean @default(true)
  has_receipt  Boolean @default(false)
  frame_serial String?

  last_service_at DateTime?
  description     String?

  created_at DateTime @default(now())

  category     Category      @relation(fields: [category_id], references: [category_id])
  listings     Listing[]
  orderDetails OrderDetail[]

  @@map("vehicles")
}

model Listing {
  listing_id    String         @id @default(uuid())
  seller_id     String
  vehicle_id    String
  status        ListingStatus
  approved_by   String?
  approved_at   DateTime?
  expires_at    DateTime?
  created_at    DateTime
  updated_at    DateTime
  approval_note String?
  cartItems     CartItem[]
  inspections   Inspection[]
  media         ListingMedia[]
  seller        User           @relation("SellerListings", fields: [seller_id], references: [user_id])
  vehicle       Vehicle        @relation(fields: [vehicle_id], references: [vehicle_id])
  messages      Message[]
  orderDetails  OrderDetail[]
  orders        Order[]
  reports       Report[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  interactions UserInteraction[] // 👈 thêm dòng này
  embedding Unsupported("vector(768)")?
  @@map("listings")
}
enum InteractionType {
  VIEW
  CLICK
  ADD_TO_CART
  REMOVE_FROM_CART
  PURCHASE
  SEARCH_CLICK
  WISHLIST_ADD
  WISHLIST_REMOVE
} 
model UserInteraction {
  interaction_id String          @id @default(uuid())
  user_id        String
  listing_id     String
  type           InteractionType
  metadata       Json?           // lưu thêm thông tin như query search, thời gian xem, v.v.
  created_at     DateTime        @default(now())

  user    User    @relation(fields: [user_id], references: [user_id])
  listing Listing @relation(fields: [listing_id], references: [listing_id])

  @@index([user_id])
  @@index([listing_id])
  @@map("user_interactions")
}
model ListingMedia {
  media_id    String    @id @default(uuid())
  listing_id  String
  type        MediaType
  file_url    String
  mime_type   String
  size_bytes  BigInt
  uploaded_at DateTime
  is_cover    Boolean   @default(false)

  listing Listing @relation(fields: [listing_id], references: [listing_id])

  @@map("listing_media")
}

enum InspectionRequestStatus {
  PENDING // chờ xác nhận lịch
  CONFIRMED // đã xác nhận lịch
  COMPLETED // đã hoàn thành (có kết quả)
  CANCELLED // đã hủy
}

model Inspection {
  inspection_id   String                  @id @default(uuid())
  listing_id      String
  requested_by_id String // người mua yêu cầu
  inspector_id    String? // người thực hiện (có thể null khi mới tạo)
  scheduled_at    DateTime? // thời gian hẹn kiểm định
  request_status  InspectionRequestStatus @default(PENDING)
  result_status   InspectionStatus? // PASSED/FAILED/EXPIRED (kết quả)
  report_url      String?
  notes           String?
  created_at      DateTime                @default(now())
  updated_at      DateTime                @updatedAt
  valid_until     DateTime? // hiệu lực của kết quả (nếu có)

  listing   Listing @relation(fields: [listing_id], references: [listing_id])
  requester User    @relation("InspectionRequester", fields: [requested_by_id], references: [user_id])
  inspector User?   @relation("Inspector", fields: [inspector_id], references: [user_id])

  @@map("inspections")
}

model Order {
  order_id        String           @id @default(uuid())
  buyer_id        String
  listing_id      String
  deposit_amount  Decimal
  status          OrderStatus
  confirmed_at    DateTime?
  created_at      DateTime
  orderAddresses  OrderAddress[]
  orderDetails    OrderDetail[]
  buyer           User             @relation("BuyerOrders", fields: [buyer_id], references: [user_id])
  listing         Listing          @relation(fields: [listing_id], references: [listing_id])
  paymentDeposits PaymentDeposit[]
  payments        Payment[]
  reviews         Review[]
  shipment        Shipment?
  transfers       Transfer[]

  @@map("orders")
}

model OrderDetail {
  order_detail_id String         @id @default(uuid())
  order_id        String
  listing_id      String
  vehicle_id      String
  quantity        Int
  unit_price      Decimal
  total_price     Decimal
  created_at      DateTime
  listing         Listing        @relation(fields: [listing_id], references: [listing_id])
  order           Order          @relation(fields: [order_id], references: [order_id])
  vehicle         Vehicle        @relation(fields: [vehicle_id], references: [vehicle_id])
  shipment_items  ShipmentItem[]

  @@map("order_details")
}

model OrderAddress {
  order_address_id String      @id @default(uuid())
  order_id         String
  address_id       String?
  address_type     AddressType
  address_snapshot String?
  created_at       DateTime
  address          Address?    @relation(fields: [address_id], references: [address_id])
  order            Order       @relation(fields: [order_id], references: [order_id])

  @@map("order_addresses")
}

model Payment {
  payment_id   String           @id @default(uuid())
  order_id     String
  order_code   BigInt?          @unique
  method       String
  amount       Decimal
  platform_fee Decimal?
  status       PaymentStatus
  created_at   DateTime
  deposits     PaymentDeposit[]
  order        Order            @relation(fields: [order_id], references: [order_id])

  @@map("payments")
}

model PaymentDeposit {
  deposit_id String   @id @default(uuid())
  payment_id String
  order_id   String
  buyer_id   String
  amount     Decimal
  note       String?
  status     String
  created_at DateTime
  buyer      User     @relation(fields: [buyer_id], references: [user_id])
  order      Order    @relation(fields: [order_id], references: [order_id])
  payment    Payment  @relation(fields: [payment_id], references: [payment_id])

  @@map("payment_deposits")
}

model Transfer {
  transfer_id    String                @id @default(uuid())
  reference_id   String                @unique
  payout_id      String?
  user_id        String?
  order_id      String?
  total_credit   Decimal?
  category       Json?
  approval_state String                @default("DRAFTING")
  created_at     DateTime              @default(now())
  updated_at     DateTime?             @updatedAt
  transactions   TransferTransaction[]
  order          Order?                @relation(fields: [order_id], references: [order_id])
  user           User?                 @relation(fields: [user_id], references: [user_id])

  @@map("transfers")
}

model TransferTransaction {
  transfer_transaction_id String    @id @default(uuid())
  transfer_id             String
  reference_id            String    @unique
  payout_transaction_id   String?
  amount                  Decimal
  description             String
  to_bin                  String?
  to_account_number       String?
  to_account_name         String?
  reference               String?
  transaction_datetime    DateTime?
  error_message           String?
  error_code              String?
  state                   String
  created_at              DateTime  @default(now())

  transfer Transfer @relation(fields: [transfer_id], references: [transfer_id], onDelete: Cascade)

  @@map("transfer_transactions")
}

model Chat {
  chat_id    String    @id @default(uuid())
  user1_id   String
  user2_id   String
  created_at DateTime  @default(now())
  user1      User      @relation("ChatUser1", fields: [user1_id], references: [user_id])
  user2      User      @relation("ChatUser2", fields: [user2_id], references: [user_id])
  messages   Message[]

  @@map("chats")
}

model Message {
  message_id  String   @id @default(uuid())
  sender_id   String
  receiver_id String?
  listing_id  String?
  content     String?
  created_at  DateTime @default(now())
  chat_id     String?
  image_url   String?
  chat        Chat?    @relation(fields: [chat_id], references: [chat_id])
  listing     Listing? @relation(fields: [listing_id], references: [listing_id])
  receiver    User?    @relation("Receiver", fields: [receiver_id], references: [user_id])
  sender      User     @relation("Sender", fields: [sender_id], references: [user_id])
  is_ai_generated Boolean @default(false)
  ai_metadata     Json? 
  @@map("messages")
}

model Review {
  review_id            String    @id @default(uuid())
  buyer_id             String?
  seller_id            String?
  reviewer_id          String
  target_id            String
  order_id             String?
  listing_id           String?
  rating               Int
  comment              String?
  is_verified_purchase Boolean   @default(false)
  status               String    @default("APPROVED")
  reported_count       Int       @default(0)
  helpful_count        Int       @default(0)
  created_at           DateTime
  updated_at           DateTime?
  buyer                User?     @relation("ReviewBuyer", fields: [buyer_id], references: [user_id])
  listing              Listing?  @relation(fields: [listing_id], references: [listing_id])
  order                Order?    @relation(fields: [order_id], references: [order_id])
  reviewer             User      @relation("Reviewer", fields: [reviewer_id], references: [user_id])
  seller               User?     @relation("ReviewSeller", fields: [seller_id], references: [user_id])
  target               User      @relation("Target", fields: [target_id], references: [user_id])
  confidence_score Float?   // điểm tin cậy (0-1)
  is_flagged       Boolean? @default(false) // đánh dấu cần kiểm tra
  analysis_result  Json?    // chi tiết phân tích (sentiment, keywords, lý do flag)
  analyzed_at      DateTime? // thời gian phân tích
  @@map("reviews")
}

enum ReportStatus {
  PENDING
  PROCESSING
  RESOLVED
  REJECTED
  CANCELLED
}

enum ReportResolution {
  WARNING
  HIDE_LISTING
  DELETE_LISTING
  BAN_USER
  NO_ACTION
  OTHER
}

model Report {
  report_id    String            @id @default(uuid())
  user_id      String
  listing_id   String
  reason       String
  description  String?
  status       ReportStatus      @default(PENDING)
  resolution   ReportResolution?
  processed_by String?
  processed_at DateTime?
  admin_notes  String?
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  listing Listing @relation(fields: [listing_id], references: [listing_id])
  user    User    @relation("UserReports", fields: [user_id], references: [user_id]) // 👈 thêm "UserReports"
  admin   User?   @relation("AdminProcessed", fields: [processed_by], references: [user_id])

  @@map("reports")
}

model Address {
  address_id     String         @id @default(uuid())
  user_id        String
  label          String?
  recipient_name String?
  phone          String?
  address_line1  String
  address_line2  String?
  ward           String?
  district       String?
  city           String?
  postal_code    String?
  country        String?
  is_default     Boolean        @default(false)
  created_at     DateTime
  user           User           @relation(fields: [user_id], references: [user_id])
  orderAddresses OrderAddress[]

  @@map("addresses")
}

model Notification {
  notification_id String           @id @default(uuid())
  user_id         String
  type            NotificationType
  title           String
  message         String
  is_read         Boolean          @default(false)
  created_at      DateTime
  link            String?
  user            User             @relation(fields: [user_id], references: [user_id])

  @@map("notifications")
}

model Cart {
  cart_id    String     @id @default(uuid())
  buyer_id   String     @unique
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  items      CartItem[]
  buyer      User       @relation("BuyerCart", fields: [buyer_id], references: [user_id])

  @@map("carts")
}

model CartItem {
  cart_item_id String   @id @default(uuid())
  cart_id      String
  listing_id   String
  quantity     Int      @default(1)
  added_at     DateTime @default(now())
  cart         Cart     @relation(fields: [cart_id], references: [cart_id], onDelete: Cascade)
  listing      Listing  @relation(fields: [listing_id], references: [listing_id])

  @@unique([cart_id, listing_id])
  @@map("cart_items")
}

model Wishlist {
  wishlist_id String         @id @default(uuid())
  user_id     String         @unique
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  user        User           @relation(fields: [user_id], references: [user_id])
  items       WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  wishlist_item_id String   @id @default(uuid())
  wishlist_id      String
  listing_id       String
  added_at         DateTime @default(now())
  listing          Listing  @relation(fields: [listing_id], references: [listing_id])
  wishlist         Wishlist @relation(fields: [wishlist_id], references: [wishlist_id], onDelete: Cascade)

  @@unique([wishlist_id, listing_id])
  @@map("wishlist_items")
}

enum ShipmentStatus {
  PENDING // Chờ lấy hàng (mới tạo, carrier chưa lấy)
  PICKED_UP // Đã lấy hàng
  IN_TRANSIT // Đang vận chuyển
  OUT_FOR_DELIVERY // Đang giao
  DELIVERED // Đã giao thành công
  FAILED // Giao thất bại
  RETURNED // Trả lại người gửi
  CANCELLED // Đã hủy
}

model ShippingMethod {
  shipping_method_id String   @id @default(uuid())
  name               String // "Giao hàng nhanh", "Giao hàng tiết kiệm", ...
  code               String   @unique // Mã tích hợp với carrier, vd: "GHN_FAST"
  carrier            String // Tên hãng vận chuyển: "GHN", "GHTK", "VNPost"
  description        String?
  base_fee           Decimal // Phí cơ bản (có thể được tính lại từ carrier)
  estimated_days     Int? // Thời gian dự kiến (ngày)
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  shipments Shipment[]
}

model Shipment {
  shipment_id        String  @id @default(uuid())
  order_id           String  @unique // Một order chỉ có một shipment chính
  shipping_method_id String? // Phương thức được chọn

  // Thông tin từ carrier
  tracking_number    String? // Mã vận đơn
  carrier            String? // Hãng vận chuyển (lưu lại nếu không dùng method)
  status             ShipmentStatus @default(PENDING)
  shipping_fee       Decimal // Phí vận chuyển thực tế
  estimated_delivery DateTime? // Ngày giao dự kiến (từ carrier)
  delivered_at       DateTime? // Ngày giao thực tế
  shipped_at         DateTime? // Ngày gửi hàng
  cancelled_at       DateTime?

  // Thời gian shop xác nhận đã chuẩn bị hàng (nếu cần)
  shop_confirmed_at DateTime?

  // Dữ liệu phản hồi từ carrier (để debug/đối soát)
  carrier_request  Json? // Request gửi đi
  carrier_response Json? // Response nhận về (khi tạo đơn)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Liên kết
  order           Order              @relation(fields: [order_id], references: [order_id])
  shipping_method ShippingMethod?    @relation(fields: [shipping_method_id], references: [shipping_method_id])
  items           ShipmentItem[]
  trackings       ShipmentTracking[]
}

model ShipmentItem {
  shipment_item_id String @id @default(uuid())
  shipment_id      String
  order_detail_id  String // Sản phẩm từ OrderDetail
  quantity         Int // Số lượng sản phẩm trong shipment này

  shipment     Shipment    @relation(fields: [shipment_id], references: [shipment_id])
  order_detail OrderDetail @relation(fields: [order_detail_id], references: [order_detail_id])

  @@unique([shipment_id, order_detail_id])
}

model ShipmentTracking {
  tracking_id String   @id @default(uuid())
  shipment_id String
  status      String // Trạng thái mô tả từ carrier (ví dụ: "Đã nhận đơn", "Đang giao",...)
  location    String? // Địa điểm cập nhật
  description String? // Mô tả chi tiết
  tracked_at  DateTime // Thời gian xảy ra cập nhật (từ carrier)
  created_at  DateTime @default(now())

  shipment Shipment @relation(fields: [shipment_id], references: [shipment_id])
}

// Bảng log webhook từ carrier (để kiểm tra, debug)
model CarrierWebhookLog {
  id           String    @id @default(uuid())
  carrier      String // "GHN", "GHTK", ...
  event_type   String // "shipping.update", "order.status", ...
  payload      Json // Toàn bộ dữ liệu webhook gửi sang
  processed    Boolean   @default(false)
  error        String?
  created_at   DateTime  @default(now())
  processed_at DateTime?
}

enum RoleName {
  USER
  INSPECTOR
  ADMIN
  AI_ASSISTANT   // 👈 thêm role cho bot

}

enum ListingStatus {
  ACTIVE
  HIDDEN
  SOLD
  EXPIRED
  PENDING_APPROVAL
  REJECTED
  APPROVED
  RESERVED
}

enum OrderStatus {
  PENDING
  DEPOSITED
  COMPLETED
  CANCELLED_BY_BUYER
  CANCELLED_BY_SELLER
  CONFIRMED
  FORFEITED
  PAID
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum NotificationType {
  MESSAGE
  ORDER
  INSPECTION
  SYSTEM
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum InspectionStatus {
  PENDING
  PASSED
  FAILED
  EXPIRED
}

enum AddressType {
  SHIPPING
  BILLING
  PICKUP
  DROPOFF
}

