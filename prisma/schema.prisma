generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  role_id   Int      @id @default(autoincrement())
  role_name RoleName @unique
  users     User[]

  @@map("roles")
}

model User {
  user_id              String           @id @default(uuid())
  full_name            String
  email                String           @unique
  phone                String           @unique
  password             String
  role_id              Int
  violation_count      Int              @default(0)
  locked_until         DateTime?
  created_at           DateTime
  ip_address           String?
  is_verified          Boolean          @default(false)
  addresses            Address[]
  cart                 Cart?            @relation("BuyerCart")
  chatUser1s           Chat[]           @relation("ChatUser1")
  chatUser2s           Chat[]           @relation("ChatUser2")
  inspectionsAssigned  Inspection[]     @relation("Inspector")
  inspectionsRequested Inspection[]     @relation("InspectionRequester")
  listings             Listing[]        @relation("SellerListings")
  messagesReceived     Message[]        @relation("Receiver")
  messagesSent         Message[]        @relation("Sender")
  notifications        Notification[]
  orders               Order[]          @relation("BuyerOrders")
  otps                 Otp[]
  paymentDeposits      PaymentDeposit[]
  reportsProcessed     Report[]         @relation("AdminProcessed")
  reports              Report[]         @relation("UserReports")
  reviewAsBuyer        Review[]         @relation("ReviewBuyer")
  reviewsGiven         Review[]         @relation("Reviewer")
  reviewAsSeller       Review[]         @relation("ReviewSeller")
  reviewsReceived      Review[]         @relation("Target")
  transfers            Transfer[]
  profile              UserProfile?
  role                 Role             @relation(fields: [role_id], references: [role_id])
  wishlist             Wishlist?

  @@map("users")
}

model Otp {
  id         String   @id @default(uuid())
  user_id    String
  code       String
  expired_at DateTime
  user       User     @relation(fields: [user_id], references: [user_id])

  @@map("otps")
}

model UserProfile {
  profile_id   String    @id @default(uuid())
  user_id      String    @unique
  dob          DateTime?
  gender       String?
  national_id  String?
  bank_account String?
  bank_name    String?
  avatar_url   String?
  created_at   DateTime
  bank_bin     String?
  user         User      @relation(fields: [user_id], references: [user_id])

  @@map("user_profiles")
}

model Category {
  category_id String     @id @default(uuid())
  name        String
  parent_id   String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [category_id])
  children    Category[] @relation("CategoryHierarchy")
  vehicles    Vehicle[]

  @@map("categories")
}

model Vehicle {
  vehicle_id      String           @id @default(uuid())
  category_id     String
  brand           String
  model           String
  year            Int
  price           Decimal
  frame_size      String?
  description     String?
  created_at      DateTime         @default(now())
  bike_type       String
  brake_type      String
  frame_serial    String?
  groupset        String?
  has_receipt     Boolean          @default(false)
  is_original     Boolean          @default(true)
  last_service_at DateTime?
  material        String
  mileage_km      Int?
  usage_level     String?
  wheel_size      String?
  condition       VehicleCondition
  listings        Listing[]
  orderDetails    OrderDetail[]
  category        Category         @relation(fields: [category_id], references: [category_id])

  @@map("vehicles")
}

model Listing {
  listing_id    String         @id @default(uuid())
  seller_id     String
  vehicle_id    String
  status        ListingStatus
  approved_by   String?
  approved_at   DateTime?
  expires_at    DateTime?
  created_at    DateTime
  updated_at    DateTime
  approval_note String?
  cartItems     CartItem[]
  inspections   Inspection[]
  media         ListingMedia[]
  seller        User           @relation("SellerListings", fields: [seller_id], references: [user_id])
  vehicle       Vehicle        @relation(fields: [vehicle_id], references: [vehicle_id])
  messages      Message[]
  orderDetails  OrderDetail[]
  orders        Order[]
  reports       Report[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@map("listings")
}

model ListingMedia {
  media_id    String    @id @default(uuid())
  listing_id  String
  type        MediaType
  file_url    String
  mime_type   String
  size_bytes  BigInt
  uploaded_at DateTime
  is_cover    Boolean   @default(false)
  listing     Listing   @relation(fields: [listing_id], references: [listing_id])

  @@map("listing_media")
}

model Inspection {
  inspection_id   String                  @id @default(uuid())
  inspector_id    String?
  listing_id      String
  report_url      String?
  valid_until     DateTime?
  created_at      DateTime                @default(now())
  notes           String?
  request_status  InspectionRequestStatus @default(PENDING)
  requested_by_id String
  result_status   InspectionStatus?
  scheduled_at    DateTime?
  updated_at      DateTime                @updatedAt
  inspector       User?                   @relation("Inspector", fields: [inspector_id], references: [user_id])
  listing         Listing                 @relation(fields: [listing_id], references: [listing_id])
  requester       User                    @relation("InspectionRequester", fields: [requested_by_id], references: [user_id])

  @@map("inspections")
}

model Order {
  order_id        String           @id @default(uuid())
  buyer_id        String
  listing_id      String
  deposit_amount  Decimal
  status          OrderStatus
  confirmed_at    DateTime?
  created_at      DateTime
  Shipment        Shipment?
  orderAddresses  OrderAddress[]
  orderDetails    OrderDetail[]
  buyer           User             @relation("BuyerOrders", fields: [buyer_id], references: [user_id])
  listing         Listing          @relation(fields: [listing_id], references: [listing_id])
  paymentDeposits PaymentDeposit[]
  payments        Payment[]
  reviews         Review[]
  transfers       Transfer[]

  @@map("orders")
}

model OrderDetail {
  order_detail_id String         @id @default(uuid())
  order_id        String
  listing_id      String
  vehicle_id      String
  quantity        Int
  unit_price      Decimal
  total_price     Decimal
  created_at      DateTime
  ShipmentItem    ShipmentItem[]
  listing         Listing        @relation(fields: [listing_id], references: [listing_id])
  order           Order          @relation(fields: [order_id], references: [order_id])
  vehicle         Vehicle        @relation(fields: [vehicle_id], references: [vehicle_id])

  @@map("order_details")
}

model OrderAddress {
  order_address_id String      @id @default(uuid())
  order_id         String
  address_id       String?
  address_type     AddressType
  address_snapshot String?
  created_at       DateTime
  address          Address?    @relation(fields: [address_id], references: [address_id])
  order            Order       @relation(fields: [order_id], references: [order_id])

  @@map("order_addresses")
}

model Payment {
  payment_id   String           @id @default(uuid())
  order_id     String
  method       String
  amount       Decimal
  platform_fee Decimal?
  status       PaymentStatus
  created_at   DateTime
  deposits     PaymentDeposit[]
  order        Order            @relation(fields: [order_id], references: [order_id])

  @@map("payments")
}

model PaymentDeposit {
  deposit_id String   @id @default(uuid())
  payment_id String
  order_id   String
  buyer_id   String
  amount     Decimal
  note       String?
  status     String
  created_at DateTime
  buyer      User     @relation(fields: [buyer_id], references: [user_id])
  order      Order    @relation(fields: [order_id], references: [order_id])
  payment    Payment  @relation(fields: [payment_id], references: [payment_id])

  @@map("payment_deposits")
}

model Transfer {
  transfer_id    String                @id @default(uuid())
  reference_id   String                @unique
  payout_id      String?
  user_id        String?
  order_id      String?
  total_credit   Decimal?
  category       Json?
  approval_state String                @default("DRAFTING")
  created_at     DateTime              @default(now())
  updated_at     DateTime?             @updatedAt
  transactions   TransferTransaction[]
  order          Order?                @relation(fields: [order_id], references: [order_id])
  user           User?                 @relation(fields: [user_id], references: [user_id])

  @@map("transfers")
}

model TransferTransaction {
  transfer_transaction_id String    @id @default(uuid())
  transfer_id             String
  reference_id            String    @unique
  payout_transaction_id   String?
  amount                  Decimal
  description             String
  to_bin                  String?
  to_account_number       String?
  to_account_name         String?
  reference               String?
  transaction_datetime    DateTime?
  error_message           String?
  error_code              String?
  state                   String
  created_at              DateTime  @default(now())
  transfer                Transfer  @relation(fields: [transfer_id], references: [transfer_id], onDelete: Cascade)

  @@map("transfer_transactions")
}

model Chat {
  chat_id    String    @id @default(uuid())
  user1_id   String
  user2_id   String
  created_at DateTime  @default(now())
  user1      User      @relation("ChatUser1", fields: [user1_id], references: [user_id])
  user2      User      @relation("ChatUser2", fields: [user2_id], references: [user_id])
  messages   Message[]

  @@map("chats")
}

model Message {
  message_id  String   @id @default(uuid())
  sender_id   String
  receiver_id String?
  listing_id  String?
  content     String?
  created_at  DateTime @default(now())
  chat_id     String?
  image_url   String?
  chat        Chat?    @relation(fields: [chat_id], references: [chat_id])
  listing     Listing? @relation(fields: [listing_id], references: [listing_id])
  receiver    User?    @relation("Receiver", fields: [receiver_id], references: [user_id])
  sender      User     @relation("Sender", fields: [sender_id], references: [user_id])

  @@map("messages")
}

model Review {
  review_id            String    @id @default(uuid())
  buyer_id             String?
  seller_id            String?
  reviewer_id          String
  target_id            String
  order_id             String?
  listing_id           String?
  rating               Int
  comment              String?
  is_verified_purchase Boolean   @default(false)
  status               String    @default("APPROVED")
  reported_count       Int       @default(0)
  helpful_count        Int       @default(0)
  created_at           DateTime
  updated_at           DateTime?
  buyer                User?     @relation("ReviewBuyer", fields: [buyer_id], references: [user_id])
  listing              Listing?  @relation(fields: [listing_id], references: [listing_id])
  order                Order?    @relation(fields: [order_id], references: [order_id])
  reviewer             User      @relation("Reviewer", fields: [reviewer_id], references: [user_id])
  seller               User?     @relation("ReviewSeller", fields: [seller_id], references: [user_id])
  target               User      @relation("Target", fields: [target_id], references: [user_id])

  @@map("reviews")
}

model Report {
  report_id    String            @id @default(uuid())
  user_id      String
  listing_id   String
  reason       String
  created_at   DateTime          @default(now())
  admin_notes  String?
  description  String?
  processed_at DateTime?
  processed_by String?
  resolution   ReportResolution?
  updated_at   DateTime          @updatedAt
  status       ReportStatus      @default(PENDING)
  listing      Listing           @relation(fields: [listing_id], references: [listing_id])
  admin        User?             @relation("AdminProcessed", fields: [processed_by], references: [user_id])
  user         User              @relation("UserReports", fields: [user_id], references: [user_id])

  @@map("reports")
}

model Address {
  address_id     String         @id @default(uuid())
  user_id        String
  label          String?
  recipient_name String?
  phone          String?
  address_line1  String
  address_line2  String?
  ward           String?
  district       String?
  city           String?
  postal_code    String?
  country        String?
  is_default     Boolean        @default(false)
  created_at     DateTime
  user           User           @relation(fields: [user_id], references: [user_id])
  orderAddresses OrderAddress[]

  @@map("addresses")
}

model Notification {
  notification_id String           @id @default(uuid())
  user_id         String
  type            NotificationType
  title           String
  message         String
  is_read         Boolean          @default(false)
  created_at      DateTime
  link            String?
  user            User             @relation(fields: [user_id], references: [user_id])

  @@map("notifications")
}

model Cart {
  cart_id    String     @id @default(uuid())
  buyer_id   String     @unique
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  items      CartItem[]
  buyer      User       @relation("BuyerCart", fields: [buyer_id], references: [user_id])

  @@map("carts")
}

model CartItem {
  cart_item_id String   @id @default(uuid())
  cart_id      String
  listing_id   String
  quantity     Int      @default(1)
  added_at     DateTime @default(now())
  cart         Cart     @relation(fields: [cart_id], references: [cart_id], onDelete: Cascade)
  listing      Listing  @relation(fields: [listing_id], references: [listing_id])

  @@unique([cart_id, listing_id])
  @@map("cart_items")
}

model Wishlist {
  wishlist_id String         @id @default(uuid())
  user_id     String         @unique
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  items       WishlistItem[]
  user        User           @relation(fields: [user_id], references: [user_id])

  @@map("wishlists")
}

model WishlistItem {
  wishlist_item_id String   @id @default(uuid())
  wishlist_id      String
  listing_id       String
  added_at         DateTime @default(now())
  listing          Listing  @relation(fields: [listing_id], references: [listing_id])
  wishlist         Wishlist @relation(fields: [wishlist_id], references: [wishlist_id], onDelete: Cascade)

  @@unique([wishlist_id, listing_id])
  @@map("wishlist_items")
}

model CarrierWebhookLog {
  id           String    @id
  carrier      String
  event_type   String
  payload      Json
  processed    Boolean   @default(false)
  error        String?
  created_at   DateTime  @default(now())
  processed_at DateTime?
}

model Shipment {
  shipment_id        String             @id
  order_id           String             @unique
  shipping_method_id String?
  tracking_number    String?
  carrier            String?
  status             ShipmentStatus     @default(PENDING)
  shipping_fee       Decimal
  estimated_delivery DateTime?
  delivered_at       DateTime?
  shipped_at         DateTime?
  cancelled_at       DateTime?
  shop_confirmed_at  DateTime?
  carrier_request    Json?
  carrier_response   Json?
  created_at         DateTime           @default(now())
  updated_at         DateTime
  orders             Order              @relation(fields: [order_id], references: [order_id])
  ShippingMethod     ShippingMethod?    @relation(fields: [shipping_method_id], references: [shipping_method_id])
  ShipmentItem       ShipmentItem[]
  ShipmentTracking   ShipmentTracking[]
}

model ShipmentItem {
  shipment_item_id String      @id
  shipment_id      String
  order_detail_id  String
  quantity         Int
  order_details    OrderDetail @relation(fields: [order_detail_id], references: [order_detail_id])
  Shipment         Shipment    @relation(fields: [shipment_id], references: [shipment_id])

  @@unique([shipment_id, order_detail_id])
}

model ShipmentTracking {
  tracking_id String   @id
  shipment_id String
  status      String
  location    String?
  description String?
  tracked_at  DateTime
  created_at  DateTime @default(now())
  Shipment    Shipment @relation(fields: [shipment_id], references: [shipment_id])
}

model ShippingMethod {
  shipping_method_id String     @id
  name               String
  code               String     @unique
  carrier            String
  description        String?
  base_fee           Decimal
  estimated_days     Int?
  is_active          Boolean    @default(true)
  created_at         DateTime   @default(now())
  updated_at         DateTime
  Shipment           Shipment[]
}

enum VehicleCondition {
  NEW
  USED
}

enum InspectionRequestStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ReportStatus {
  PENDING
  PROCESSING
  RESOLVED
  REJECTED
  CANCELLED
}

enum ReportResolution {
  WARNING
  HIDE_LISTING
  DELETE_LISTING
  BAN_USER
  NO_ACTION
  OTHER
}

enum RoleName {
  USER
  INSPECTOR
  ADMIN
}

enum ListingStatus {
  ACTIVE
  HIDDEN
  SOLD
  EXPIRED
  PENDING_APPROVAL
  REJECTED
  APPROVED
  RESERVED
}

enum OrderStatus {
  PENDING
  DEPOSITED
  COMPLETED
  CANCELLED_BY_BUYER
  CANCELLED_BY_SELLER
  CONFIRMED
  FORFEITED
  PAID
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum NotificationType {
  MESSAGE
  ORDER
  INSPECTION
  SYSTEM
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum InspectionStatus {
  PENDING
  PASSED
  FAILED
  EXPIRED
}

enum AddressType {
  SHIPPING
  BILLING
  PICKUP
  DROPOFF
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}
